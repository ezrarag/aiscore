# Copy this file to Server/.env. Never commit Server/.env.
# Primary provider: openai, anthropic, or gemini.
LLM_PROVIDER=openai
# Optional providers tried after eligible missing-key, auth, quota, billing, or capability failures.
LLM_FALLBACK_ORDER=anthropic,gemini

OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-2

ANTHROPIC_API_KEY=
ANTHROPIC_TEXT_MODEL=claude-sonnet-4-5
# Anthropic does not currently provide an image-generation API.
ANTHROPIC_IMAGE_MODEL=
ANTHROPIC_VERSION=2023-06-01

GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
# Set this only to a Gemini model that supports IMAGE response output.
GEMINI_IMAGE_MODEL=

# Reserved for the upcoming Google Drive OAuth importer.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8787/auth/google/callback
